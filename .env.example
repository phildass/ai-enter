# API Base URL (optional)
# Leave empty (default) so the browser uses relative paths on the same origin.
# Set to an absolute URL only when the Next.js API routes are served from a
# different host, e.g. a separate Azure Functions deployment.
# Example: NEXT_PUBLIC_API_BASE_URL=https://api.aienter.in
NEXT_PUBLIC_API_BASE_URL=

# Public site URL used for Razorpay payment-link callbacks (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://aienter.in

# Razorpay Configuration (service-specific)
# iiskills — legacy names RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET also work if _IISKILLS vars are unset
RAZORPAY_KEY_ID_IISKILLS=your_iiskills_razorpay_key_id_here
RAZORPAY_KEY_SECRET_IISKILLS=your_iiskills_razorpay_key_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID_IISKILLS=your_iiskills_razorpay_key_id_here
#
# uriq.in
RAZORPAY_KEY_ID_URIQ=your_uriq_razorpay_key_id_here
RAZORPAY_KEY_SECRET_URIQ=your_uriq_razorpay_key_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID_URIQ=your_uriq_razorpay_key_id_here
# Webhook secret — copy from https://dashboard.razorpay.com/app/webhooks
# Used to verify the X-Razorpay-Signature header on incoming webhook events.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Supabase Configuration
# Get these from your Supabase project settings
# URL format: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Handoff Signing Secret (shared between ai-enter and jai-bharat / jai-kisan origin sites)
# Used to verify signed tokens sent by those origin sites when initiating payment.
HANDOFF_SIGNING_SECRET=your_handoff_signing_secret_here

# Origin Webhook Secret (shared between ai-enter and jai-bharat / jai-kisan origin sites)
# Used to sign outgoing webhook callbacks so origin sites can verify them.
# Header sent: X-AI-ENTER-SIGNATURE: hmac_sha256(rawBody, ORIGIN_WEBHOOK_SECRET)
# NOT used for iiskills (see AIENTER_CONFIRMATION_SIGNING_SECRET below).
ORIGIN_WEBHOOK_SECRET=your_origin_webhook_secret_here

# Webhook URLs (jai-bharat, jai-kisan, and iisacademy receive payment success callbacks from ai-enter)
# Format: POST https://<origin>/api/payments/ai-enter/callback
JAI_KISAN_WEBHOOK_URL=https://jaikisan.cloud/api/payments/ai-enter/callback
JAI_BHARAT_WEBHOOK_URL=https://jaibharat.cloud/api/payments/ai-enter/callback
IISACADEMY_WEBHOOK_URL=https://iisacademy.in/api/payments/ai-enter/callback

# -----------------------------------------------------------------------
# iiskills.in payment integration
# -----------------------------------------------------------------------

# Secret used to verify JWT tokens issued by iiskills generate-token endpoint.
# Must match the secret configured on the iiskills server.
IISKILLS_PAYMENT_TOKEN_SECRET=your_iiskills_payment_token_secret_here

# Secret used to sign outgoing confirmation requests to iiskills.
# Header sent: x-aienter-signature: hmac_sha256(rawBody, AIENTER_CONFIRMATION_SIGNING_SECRET)
# Must match the secret configured on the iiskills server.
AIENTER_CONFIRMATION_SIGNING_SECRET=your_aienter_confirmation_signing_secret_here

# iiskills canonical confirm endpoint (optional; defaults to the value below).
# Override only if the iiskills deployment uses a different URL.
IISKILLS_CONFIRM_URL=https://iiskills.in/api/payments/confirm

# -----------------------------------------------------------------------
# uriq.in payment integration
# -----------------------------------------------------------------------

# Secret used to verify JWT tokens issued by uriq payment-token endpoint.
URIQ_PAYMENT_TOKEN_SECRET=your_uriq_payment_token_secret_here

# Secret used to sign outgoing confirmation requests to uriq.in.
URIQ_CONFIRMATION_SIGNING_SECRET=your_uriq_confirmation_signing_secret_here

# uriq.in canonical confirm endpoint (optional; defaults to the value below).
URIQ_CONFIRM_URL=https://uriq.in/api/payments/confirm
